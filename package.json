{
  "name": "viking",
  "version": "0.1.0",
  "main": "main.js",
  "scripts": {
    "start": "npm run build && concurrently \"npm run watch\" \"electron .\"",
    "watch": "esbuild src/index.tsx --bundle --outfile=dist/renderer.js --watch --loader:.js=jsx --define:process.env.NODE_ENV='\"development\"'",
    "build": "esbuild src/index.tsx --bundle --outfile=dist/renderer.js --loader:.js=jsx --define:process.env.NODE_ENV='\"development\"'"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "esbuild": "^0.19.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.0.1",
    "typescript": "^5.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  }
}
